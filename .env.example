# === Database ===
DATABASE_URL=sqlite:///serviceinbox.db

# === Twilio (inbound SMS) ===
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+15551234567
TWILIO_VERIFY_SIGNATURE=false   # Set true in production

# === Email Ingestion (IMAP) ===
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your-agency@gmail.com
IMAP_PASSWORD=your_gmail_app_password_here
IMAP_FOLDER=INBOX
IMAP_POLL_INTERVAL_SECONDS=30

# === Outbound Email (SMTP) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-agency@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here
SMTP_FROM_NAME=ABC Insurance Agency
SMTP_FROM_EMAIL=your-agency@gmail.com

# === App ===
APP_TITLE=ServiceInbox Lite
APP_ENV=development
APP_BASE_URL=http://localhost:8000
SECRET_KEY=change-me-in-production

# === Digest ===
DIGEST_SCHEDULE=08:00,12:00,16:00   # Comma-separated HH:MM (local time)
DIGEST_RECIPIENTS=                    # Comma-separated emails to receive digests
DIGEST_TIMEZONE=America/New_York
