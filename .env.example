# === Database ===
DATABASE_URL=sqlite:///wayos_relay.db

# === Twilio (inbound SMS) ===
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+15551234567

# === Email Ingestion (IMAP) ===
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your-agency@example.com
IMAP_PASSWORD=your_app_password_here
IMAP_FOLDER=INBOX
IMAP_POLL_INTERVAL_SECONDS=60

# === Outbound Email (SMTP) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-agency@example.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM_NAME=ABC Insurance Agency
SMTP_FROM_EMAIL=your-agency@example.com

# === Anthropic (LLM classifier) ===
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# === App ===
APP_TITLE=wayos relay
APP_ENV=development
SECRET_KEY=change-me-in-production
